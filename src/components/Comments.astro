---
// Client-only comments island. Fetches approved comments for the post and posts
// new ones (held for moderation). Backed by /api/comments/[slug] (Pages Function
// + D1). See docs/specs/active/comments.md.
interface Props {
  slug: string;
}
const { slug } = Astro.props;
const sitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY || '';
---
<section class="comments" aria-labelledby="comments-heading">
  <h2 id="comments-heading" class="comments-heading">Comments</h2>

  <ol class="comment-list" data-comment-list>
    <li class="comment-empty" data-comment-status>Loading…</li>
  </ol>

  <form class="comment-form" data-comment-form novalidate>
    <p class="cf-reply-banner" data-reply-banner hidden>
      <span>Replying to <strong data-reply-to></strong></span>
      <button type="button" data-reply-cancel>Cancel reply</button>
    </p>
    <div class="cf-grid">
      <label class="cf-field">
        <span>Name</span>
        <input type="text" name="author" maxlength="80" required autocomplete="name" />
      </label>
      <label class="cf-field">
        <span>Email <em>(optional, never shown)</em></span>
        <input type="email" name="email" autocomplete="email" />
      </label>
    </div>
    <label class="cf-field">
      <span>Comment</span>
      <textarea name="body" rows="5" maxlength="5000" required></textarea>
    </label>

    {/* Honeypot: hidden from people, tempting to bots. */}
    <input
      class="cf-honeypot"
      type="text"
      name="website"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
    />

    {sitekey && <div class="cf-turnstile" data-sitekey={sitekey}></div>}

    <div class="cf-actions">
      <button type="submit" data-comment-submit>Post comment</button>
      <p class="cf-msg" data-comment-msg role="status" aria-live="polite"></p>
    </div>
  </form>
</section>

<script define:vars={{ slug }}>
  (function () {
    const root = document.querySelector('.comments');
    if (!root) return;
    const list = root.querySelector('[data-comment-list]');
    const form = root.querySelector('[data-comment-form]');
    const msg = root.querySelector('[data-comment-msg]');
    const submit = root.querySelector('[data-comment-submit]');
    const banner = root.querySelector('[data-reply-banner]');
    const replyToName = root.querySelector('[data-reply-to]');
    const replyCancel = root.querySelector('[data-reply-cancel]');
    const api = `/api/comments/${encodeURIComponent(slug)}`;

    // Threading is one level deep: a reply's parent is normalised to the
    // top-level ancestor so replies-to-replies don't deepen the tree.
    let replyParentId = null;

    function resetReply() {
      replyParentId = null;
      banner.hidden = true;
      replyToName.textContent = '';
      root.appendChild(form); // back to its natural spot below the list
    }

    function startReply(parentId, author, li) {
      replyParentId = parentId;
      replyToName.textContent = author;
      banner.hidden = false;
      li.appendChild(form); // relocate the single form under the target comment
      form.querySelector('[name="author"]').focus();
    }

    const fmt = (ms) =>
      new Date(ms).toLocaleDateString('en-GB', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });

    function setStatus(text, kind) {
      list.innerHTML = '';
      const li = document.createElement('li');
      li.className = 'comment-empty';
      if (kind) li.dataset.kind = kind;
      li.textContent = text;
      list.appendChild(li);
    }

    function buildCommentEl(node) {
      const li = document.createElement('li');
      li.className = 'comment';

      const head = document.createElement('p');
      head.className = 'comment-head';
      const who = document.createElement('span');
      who.className = 'comment-author';
      who.textContent = node.author;
      const when = document.createElement('time');
      when.className = 'comment-date';
      when.textContent = fmt(node.created_at);
      head.append(who, when);

      const body = document.createElement('div');
      body.className = 'comment-body';
      // Plain text only — preserve line breaks, never inject HTML.
      for (const para of String(node.body).split(/\n{2,}/)) {
        const p = document.createElement('p');
        p.textContent = para;
        body.appendChild(p);
      }

      const actions = document.createElement('p');
      actions.className = 'comment-actions';
      const replyBtn = document.createElement('button');
      replyBtn.type = 'button';
      replyBtn.className = 'comment-reply-btn';
      replyBtn.textContent = 'Reply';
      // One level deep: replying to a reply attaches to its top-level ancestor.
      replyBtn.addEventListener('click', () => {
        const parentId = node.parent_id != null ? node.parent_id : node.id;
        startReply(parentId, node.author, li);
      });
      actions.appendChild(replyBtn);
      li.append(head, body, actions);

      if (node.children.length) {
        const replies = document.createElement('ol');
        replies.className = 'comment-replies';
        for (const child of node.children) replies.appendChild(buildCommentEl(child));
        li.appendChild(replies);
      }
      return li;
    }

    function render(comments) {
      list.innerHTML = '';
      if (!comments.length) {
        setStatus('No comments yet.');
        return;
      }
      // Build a tree from the flat, time-ordered list using parent_id.
      const byId = new Map();
      for (const c of comments) byId.set(c.id, { ...c, children: [] });
      const roots = [];
      for (const node of byId.values()) {
        const parent = node.parent_id != null ? byId.get(node.parent_id) : null;
        if (parent) parent.children.push(node);
        else roots.push(node);
      }
      for (const root of roots) list.appendChild(buildCommentEl(root));
    }

    async function load() {
      try {
        const res = await fetch(api, { headers: { accept: 'application/json' } });
        if (!res.ok) throw new Error('load failed');
        const data = await res.json();
        render(data.comments || []);
      } catch {
        setStatus('Comments could not load.', 'error');
      }
    }

    replyCancel.addEventListener('click', resetReply);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.textContent = '';
      const fd = new FormData(form);
      const payload = {
        author: fd.get('author'),
        email: fd.get('email'),
        body: fd.get('body'),
        parent_id: replyParentId,
        website: fd.get('website'), // honeypot
        turnstileToken: fd.get('cf-turnstile-response') || '',
      };
      submit.disabled = true;
      try {
        const res = await fetch(api, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (res.status === 202) {
          form.reset();
          resetReply();
          if (window.turnstile) window.turnstile.reset();
          msg.dataset.kind = 'ok';
          msg.textContent = 'Thanks — your comment is awaiting moderation.';
        } else {
          msg.dataset.kind = 'error';
          msg.textContent = data.error || 'Something went wrong.';
        }
      } catch {
        msg.dataset.kind = 'error';
        msg.textContent = 'Network error. Please try again.';
      } finally {
        submit.disabled = false;
      }
    });

    load();
  })();
</script>
